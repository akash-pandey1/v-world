# Database Configuration
MONGO_URI=mongodb://localhost:27017/v-world
MONGO_URI_DEV=mongodb://localhost:27017/v-world-dev
MONGODB_URI_ATLAS=mongodb+srv://username:password@cluster.mongodb.net/v-world-prod

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-here

# Server Configuration
PORT=3001
NODE_ENV=development

# Note: PORT can be set by your hosting platform (Heroku, Railway, etc.)
# For local development, it defaults to 3001

# Frontend URLs (for CORS)
FRONTEND_URL=http://localhost:3000
# Production frontend URL (for CORS when NODE_ENV=production)
FRONTEND_URL_PROD=https://your-vercel-domain.vercel.app 